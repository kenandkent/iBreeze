{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bundled Assets Manifest",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "size": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "required": ["name", "version", "sha256"]
      }
    }
  },
  "required": ["version", "assets"]
}
